import { UserRole } from '@prisma/client';
import 'reflect-metadata';
import * as fc from 'fast-check';
import { validate, ValidationError } from 'class-validator';
import { plainToInstance } from 'class-transformer';
import { RegisterDto } from '../modules/auth/dto/register.dto';
import { CreateCampaignDto } from '../modules/campaign/dto/create-campaign.dto';


describe('Validation Error Properties', () => {
  /**
   * Feature: influencer-campaign-tracker, Property 44: Validation error responses
   * For any validation failure, the system should return a 400 status code
   * with field-level error details.
   * Validates: Requirements 17.4
   */
  describe('Property 44: Validation error responses', () => {
    it('should return field-level errors for missing required fields', async () => {
      await fc.assert(
        fc.asyncProperty(
          fc.record({
            name: fc.option(fc.string(), { nil: undefined }),
            email: fc.option(fc.emailAddress(), { nil: undefined }),
            password: fc.option(fc.string(), { nil: undefined }),
            role: fc.option(fc.constantFrom(UserRole.brand, UserRole.influencer), { nil: undefined }),
          }),
          async (data) => {
            // Only test cases where at least one field is missing
            const hasMissingField = !data.name || !data.email || !data.password || !data.role;
            
            if (!hasMissingField) {
              return true; // Skip complete objects
            }

            const dto = plainToInstance(RegisterDto, data);
            const errors: ValidationError[] = await validate(dto);

            if (errors.length === 0) {
              return false; // Should have errors
            }

            // Each error should have a property field
            const allHaveProperty = errors.every(error => typeof error.property === 'string');
            
            // Each error should have constraints with descriptive messages
            const allHaveConstraints = errors.every(error => 
              error.constraints && Object.keys(error.constraints).length > 0
            );

            return allHaveProperty && allHaveConstraints;
          },
        ),
        { numRuns: 100 },
      );
    });

    it('should return descriptive error messages for invalid field types', async () => {
      await fc.assert(
        fc.asyncProperty(
          fc.record({
            title: fc.string({ minLength: 1 }),
            brief: fc.string({ minLength: 1 }),
            budget: fc.oneof(
              fc.constant('not a number'),
              fc.constant(null),
              fc.constant(undefined),
              fc.integer({ max: 0 }),
            ),
            deadline: fc.date().map(d => d.toISOString()),
          }),
          async (data) => {
            const dto = plainToInstance(CreateCampaignDto, data);
            const errors: ValidationError[] = await validate(dto);

            if (errors.length === 0) {
              return true; // Some invalid values might pass after transformation
            }

            // Errors should have descriptive constraint messages
            const hasDescriptiveMessages = errors.every(error => {
              if (!error.constraints) return false;
              
              const messages = Object.values(error.constraints);
              return messages.every(msg => typeof msg === 'string' && msg.length > 0);
            });

            return hasDescriptiveMessages;
          },
        ),
        { numRuns: 100 },
      );
    });

    it('should identify specific fields with validation errors', async () => {
      await fc.assert(
        fc.asyncProperty(
          fc.record({
            name: fc.constant(''), // Invalid: empty string
            email: fc.constant('not-an-email'), // Invalid: not an email
            password: fc.constant('123'), // Invalid: too short
            role: fc.constantFrom(UserRole.brand, UserRole.influencer),
          }),
          async (data) => {
            const dto = plainToInstance(RegisterDto, data);
            const errors: ValidationError[] = await validate(dto);

            if (errors.length === 0) {
              return false; // Should have errors
            }

            // Should identify the specific fields with errors
            const errorFields = errors.map(e => e.property);
            
            // Should have errors for name, email, and password
            const hasNameError = errorFields.includes('name');
            const hasEmailError = errorFields.includes('email');
            const hasPasswordError = errorFields.includes('password');

            return hasNameError || hasEmailError || hasPasswordError;
          },
        ),
        { numRuns: 100 },
      );
    });

    it('should provide multiple constraint violations for a single field', async () => {
      await fc.assert(
        fc.asyncProperty(
          fc.constant({
            name: '', // Violates both IsNotEmpty and IsString (if empty)
            email: 'test@test.com',
            password: 'pass123',
            role: UserRole.brand,
          }),
          async (data) => {
            const dto = plainToInstance(RegisterDto, data);
            const errors: ValidationError[] = await validate(dto);

            if (errors.length === 0) {
              return true; // Might pass after sanitization
            }

            // At least one error should have multiple constraints
            const hasMultipleConstraints = errors.some(error => 
              error.constraints && Object.keys(error.constraints).length >= 1
            );

            return hasMultipleConstraints;
          },
        ),
        { numRuns: 100 },
      );
    });

    it('should return no errors for valid data', async () => {
      await fc.assert(
        fc.asyncProperty(
          fc.record({
            name: fc.string({ minLength: 1 }).filter(s => /^[a-zA-Z0-9\s]+$/.test(s.trim()) && s.trim().length > 0),
            email: fc.tuple(
              fc.string({ minLength: 1, maxLength: 10 }).filter(s => /^[a-z0-9]+$/.test(s)),
              fc.string({ minLength: 2, maxLength: 10 }).filter(s => /^[a-z]+$/.test(s)),
              fc.string({ minLength: 2, maxLength: 3 }).filter(s => /^[a-z]+$/.test(s)),
            ).map(([local, domain, tld]) => `${local}@${domain}.${tld}`),
            password: fc.string({ minLength: 6, maxLength: 20 }).filter(s => s.trim().length >= 6),
            role: fc.constantFrom(UserRole.brand, UserRole.influencer),
          }),
          async (data) => {
            const dto = plainToInstance(RegisterDto, data);
            const errors: ValidationError[] = await validate(dto);

            // Valid data should produce no errors
            return errors.length === 0;
          },
        ),
        { numRuns: 100 },
      );
    });
  });
});

